rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    // Admin Check - email must match (case-insensitive)
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email.lower() == 'offerbazar00100@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Entity Validation: Product
    function isValidProduct(data) {
      let requiredFields = ['title', 'price', 'imageUrl', 'originalLink', 'category', 'addedBy', 'createdAt', 'updatedAt', 'dealType', 'isFlashDeal', 'badgeTag', 'description', 'originalPrice'];
      return data.keys().hasAll(requiredFields)
          && data.title is string && data.title.size() > 0 && data.title.size() <= 1000
          && data.price is number && data.price >= 0
          && data.originalPrice is number && data.originalPrice >= 0
          && data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 5000
          && data.originalLink is string && data.originalLink.size() > 0 && data.originalLink.size() <= 5000
          && data.category is string && data.category.size() <= 200
          && data.dealType in ['loot', 'coupon', 'best_offer']
          && data.isFlashDeal is bool
          && data.badgeTag is string
          && data.description is string
          && data.addedBy is string && data.addedBy.size() > 0
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    // Paths
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      // Products are public read
      allow get: if true;
      allow list: if true;
      
      // Only Admins can manage products
      // NOTE: Removed strict timestamp equality check - serverTimestamp() is validated server-side
      allow create: if isAdmin() && isValidProduct(incoming());
                    
      allow update: if isAdmin() && isValidProduct(incoming());
                    
      allow delete: if isAdmin();
    }
  }
}
