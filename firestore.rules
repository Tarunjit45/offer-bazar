rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    
    // Admin Check
    // "rupubiswas60@gmail.com" acts as the bootstrapped admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'Offerbazar00100@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // Entity Validation: AdminConfig
    function isValidAdminConfig(data) {
      return data.keys().hasAll(['email', 'createdAt', 'updatedAt']) && data.keys().size() == 3
          && data.email is string && data.email.size() > 0 && data.email.size() <= 200
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    // Entity Validation: Product
    function isValidProduct(data) {
      // Required fields for the new segmented system
      let requiredFields = ['title', 'price', 'imageUrl', 'originalLink', 'category', 'addedBy', 'createdAt', 'updatedAt', 'dealType', 'isFlashDeal', 'badgeTag', 'description'];
      return data.keys().hasAll(requiredFields)
          && data.title is string && data.title.size() > 0 && data.title.size() <= 500
          && data.price is number && data.price >= 0
          && data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() <= 1000
          && data.originalLink is string && data.originalLink.size() > 0 && data.originalLink.size() <= 1500
          && data.category is string && data.category.size() <= 100
          && data.dealType in ['loot', 'coupon', 'best_offer']
          && data.isFlashDeal is bool
          && data.badgeTag is string
          && data.description is string
          && data.addedBy is string
          && data.createdAt is timestamp
          && data.updatedAt is timestamp;
    }

    // Paths
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if false;
      allow create: if isAdmin();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      // Products are public read
      allow get: if isValidId(productId);
      allow list: if true; // Public catalog
      
      // Only Admins can manage products
      allow create: if isAdmin()
                    && isValidId(productId)
                    && isValidProduct(incoming())
                    && incoming().createdAt == request.time
                    && incoming().updatedAt == request.time;
                    
      allow update: if isAdmin()
                    && isValidId(productId)
                    && isValidProduct(incoming())
                    && incoming().createdAt == existing().createdAt
                    && incoming().addedBy == existing().addedBy
                    && incoming().updatedAt == request.time;
                    
      allow delete: if isAdmin() && isValidId(productId);
    }
  }
}
